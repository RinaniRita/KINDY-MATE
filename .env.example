# ==========================================
# KINDY-MATE GLOBAL ENVIRONMENT CONFIGURATION
# ==========================================

# --- Django Backend Environment ---
DJANGO_SECRET_KEY=django-insecure-kindy-mate-change-this-in-prod
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
FRONTEND_URL=http://localhost:3000

# --- PostgreSQL Database ---
POSTGRES_DB=kindy_mate_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=supersecurepassword123
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Next.js Frontend Environment ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_ENV=development

# --- Optional AI Providers ---
AI_PROVIDER=scripted
AI_ENABLE_CLOUD=false
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
